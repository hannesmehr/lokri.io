# ---- Database ----
# Neon Postgres (EU region). pgvector extension must be enabled.
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=""

# ---- Better-Auth ----
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Public URL the app runs on (no trailing slash).
BETTER_AUTH_URL="http://localhost:3000"

# ---- Vercel Blob ----
# Create a Blob store in Vercel and copy the read/write token here.
BLOB_READ_WRITE_TOKEN=""

# ---- Vercel AI Gateway ----
# Used for embeddings (openai/text-embedding-3-small by default).
AI_GATEWAY_API_KEY=""

# ---- Rate Limiting (Upstash Redis) ----
# Strongly recommended for production. Without these, rate-limiting is
# disabled (with a warning in prod) and all endpoints are unprotected against
# abuse. Create a free Redis @ https://console.upstash.com/ or via the
# Vercel Marketplace integration.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---- Resend (Mailer) ----
# Sending-only API key for transactional emails (verification, reset, …).
RESEND_API_KEY=""

# ---- Per-account S3 storage configs ----
# Derives the AES-256-GCM key for encrypting S3 credentials at rest. Falls
# back to BETTER_AUTH_SECRET when empty. Rotating this invalidates all
# stored configs — users would have to re-enter their bucket credentials.
STORAGE_CONFIG_KEY=""

# ---- PayPal (developer.paypal.com → Apps & Credentials) ----
# sandbox | live — controls Environment.Sandbox vs Production
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"

# ---- Invoice metadata (printed on the generated PDFs) ----
INVOICE_COMPANY_NAME=""
INVOICE_STREET=""
INVOICE_CITY=""
INVOICE_COUNTRY="Deutschland"
INVOICE_EMAIL=""
# 0.19 = 19% VAT. Set 0 for Kleinunternehmer (§ 19 UStG — note auto-added).
INVOICE_TAX_RATE="0.19"
INVOICE_TAX_ID=""
INVOICE_BANK_NAME=""
INVOICE_IBAN=""
INVOICE_BIC=""
